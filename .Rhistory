fetch_downstream <- function (elements, genes, output_file){
precede_index <-precede(elements,genes, select = "first")
valid <- !is.na(precede_index)
downstream_gene_name <- rep(NA_character_, length(elements))
downstream_gene_name[valid] <- gene_names[precede_index[valid]]
downstream_gene_strand <- rep(NA_character_, length(elements))
downstream_gene_strand[valid] <- as.character(strand(genes))[precede_index[valid]]
# Calculate distance between each elements subject and its downstream gene
distance_to_downstream <- rep(NA_integer_, length(elements))
distance_to_downstream[valid] <- distance(elements[valid], genes[precede_index[valid]])
# Split genes by strand
genes_plus  <- genes[as.character(strand(genes)) == "+"]
genes_minus <- genes[as.character(strand(genes)) == "-"]
# For each valid elements, find nearest gene on the opposite strand
# First determine the opposite strand for each elements hit based on downstream gene strand
opposite_gene_name   <- rep(NA_character_, length(elements))
opposite_gene_strand <- rep(NA_character_, length(elements))
distance_to_opposite <- rep(NA_integer_,   length(elements))
is_opposite_closer   <- rep(NA,             length(elements))
# Split valid indices by downstream strand
valid_plus  <- valid & downstream_gene_strand == "+"  # downstream is +, so search -
valid_minus <- valid & downstream_gene_strand == "-"  # downstream is -, so search +
# Process + downstream genes: find nearest on - strand
if (any(valid_plus) & length(genes_minus) > 0) {
idx <- nearest(elements[valid_plus], genes_minus, select = "arbitrary", ignore.strand = TRUE)
not_na <- !is.na(idx)
tmp_names    <- rep(NA_character_, sum(valid_plus))
tmp_strand   <- rep(NA_character_, sum(valid_plus))
tmp_dist     <- rep(NA_integer_,   sum(valid_plus))
tmp_names[not_na]  <- mcols(genes_minus)$Name[idx[not_na]]
tmp_strand[not_na] <- "-"
tmp_dist[not_na]   <- distance(elements[valid_plus][not_na], genes_minus[idx[not_na]], ignore.strand = TRUE)
opposite_gene_name[valid_plus]   <- tmp_names
opposite_gene_strand[valid_plus] <- tmp_strand
distance_to_opposite[valid_plus] <- tmp_dist
}
# Process - downstream genes: find nearest on + strand
if (any(valid_minus) & length(genes_plus) > 0) {
idx <- nearest(elements[valid_minus], genes_plus, select = "arbitrary", ignore.strand = TRUE)
not_na <- !is.na(idx)
tmp_names    <- rep(NA_character_, sum(valid_minus))
tmp_strand   <- rep(NA_character_, sum(valid_minus))
tmp_dist     <- rep(NA_integer_,   sum(valid_minus))
tmp_names[not_na]  <- mcols(genes_plus)$Name[idx[not_na]]
tmp_strand[not_na] <- "+"
tmp_dist[not_na]   <- distance(elements[valid_minus][not_na], genes_plus[idx[not_na]], ignore.strand = TRUE)
opposite_gene_name[valid_minus]   <- tmp_names
opposite_gene_strand[valid_minus] <- tmp_strand
distance_to_opposite[valid_minus] <- tmp_dist
}
is_opposite_closer <- distance_to_opposite < distance_to_downstream
# Build per-hit data frame (one row per elements entry)
per_hit_df <- data.frame(
elements_index              = seq_along(elements),
elements_seqname            = as.character(seqnames(elements)),
elements_start              = start(elements),
elements_end                = end(elements),
elements_strand             = as.character(strand(elements)),
GeneID        = downstream_gene_name,
downstream_gene_strand = downstream_gene_strand,
distance_to_downstream = distance_to_downstream,
opposite_strand_gene   = opposite_gene_name,
opposite_gene_strand   = opposite_gene_strand,
distance_to_opposite   = distance_to_opposite,
is_opposite_closer     = is_opposite_closer,
stringsAsFactors       = FALSE
)
per_hit_df <- per_hit_df[!is_opposite_closer | is.na(is_opposite_closer), ]
# Generate clean table for saving
clean_df <- data.frame (
elements_seq = elements$sequence[per_hit_df$elements_index],
elements_pval = elements$pvalue[per_hit_df$elements_index],
downstream_gene = per_hit_df$GeneID,
distance_to_downstream = per_hit_df$distance_to_downstream
)
write.xlsx(clean_df, file = output_file)
}
fetch_downstream(gr2, genes, output_file)
output_file_JASPAR <- "MA2169_1_downstream_genes.xlsx"
output_fie_Canon <- "CanonicalHSE_downstream_genes.xlsx"
gff_genome <- "strongyloides_stercoralis.PRJEB528.WBPS19.annotations.gff3"
gff_JASPAR_FIMO <- "MA2169_1_FIMO.gff3"
gff_Canon_FIMO <- "CanonicalHSE_FIMO.gff3"
output_file_JASPAR <- "MA2169_1_downstream_genes.xlsx"
output_fie_Canon <- "CanonicalHSE_downstream_genes.xlsx"
# Load GFF3 files as GRanges objects
gr1 <- import(gff_genome, format = "gff3")
gr2 <- import(gff_JASPAR_FIMO, format = "gff3")
gr3 <- import(gff_Canon_FIMO, format = "gff3")
# Filter genomic gff3 for genes only (feature type "gene") and extract gene names
genes <- gr1[gr1$type == "gene"]
fetch_downstream(gr2, genes, output_file_JASPAR)
fetch_downstream(gr3, genes, output_fie_Canon)
