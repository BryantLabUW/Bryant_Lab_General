set_status("Scanning... folders with 200+ files will be summarised.", MUTED)
tryCatch({
results <- scan_documents(sp)
if (nrow(results) == 0) {
set_status("Scan complete — no matching documents found.", WARN)
} else {
save_results(results, svp,
sheet_name = tn,
disk_info  = disk_info,
scan_path  = sp)
size_mb <- round(sum(results$size_kb) / 1024, 2)
free_note <- if (!is.null(disk_info))
sprintf(" · %.2f GB free on drive", disk_info$free_gb) else ""
set_status(sprintf(
"Done: %d file%s found (%.2f MB total)%s. Saved to: %s",
nrow(results),
if (nrow(results) == 1L) "" else "s",
size_mb, free_note, svp),
SUCCESS)
}
}, error = function(e) {
set_status(paste("Error:", conditionMessage(e)), ERROR)
})
tkconfigure(run_btn, state = "normal", background = ACCENT)
}
tkconfigure(run_btn, command = do_scan)
tkfocus(root)
tkwait.window(root)
}
